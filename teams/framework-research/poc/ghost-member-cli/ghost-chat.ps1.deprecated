<#
.SYNOPSIS
PoC ghost-member CLI for cross-host chat into a remote AI team.

.DESCRIPTION
Verifies RFC #66 (ghost-member pattern) Findings 1-3 on the
Windows-local-dev <-> apex-research-on-remote-Linux substrate pair.

Architecture (per PO 2026-05-12):
  - CLI runs on Windows local-dev (NOT on apex host).
  - Remote team interaction is via single ssh invocations (no persistent connection
    in the sketch grade; -o ControlMaster could be added later if latency demands).
  - Long-running watch loop polls our own inbox file on apex via ssh.
  - PO arranges manual ghost registration in apex's config.json beforehand.
  - This script NEVER writes to apex's config.json (ACL-is-one-sided discipline).

Reads ssh details from ~/bin/rc-deployments.json (shared with rc-connect.ps1).
Deployment alias is hard-coded to 'apex-research' for the PoC.

.PARAMETER Name
The ghost name registered on apex side. MANDATORY. CLI watches
~/.claude/teams/apex-research/inboxes/<Name>.json for incoming messages.

.PARAMETER Target
Optional initial send-target. Can be changed in-CLI with /target <name>.

.EXAMPLE
PS> .\ghost-chat.ps1 -Name brunel
PS> .\ghost-chat.ps1 -Name brunel -Target team-lead

.NOTES
PoC / sketch grade. NOT for production.
(*FR:Brunel*) 2026-05-12 S31
#>

param(
    [Parameter(Mandatory = $true, HelpMessage = "Ghost name registered on apex side")]
    [string]$Name,

    [Parameter(Mandatory = $false)]
    [string]$Target = ""
)

# === UTF-8 console wiring ===
# PowerShell on Windows reads ssh/jq stdout via [Console]::OutputEncoding, which
# defaults to the OEM code page (CP850/CP437/CP1252 depending on locale). Apex
# writes UTF-8; without these three lines, multi-byte chars (a-umlauts, em-dashes,
# emojis) render as mojibake. Forcing UTF-8 in/out makes round-trip clean.
[Console]::OutputEncoding = [System.Text.Encoding]::UTF8
[Console]::InputEncoding  = [System.Text.Encoding]::UTF8
$OutputEncoding           = [System.Text.Encoding]::UTF8

# === Config (from ~/bin/rc-deployments.json) ===

$registryPath = Join-Path $env:USERPROFILE "bin\rc-deployments.json"
if (-not (Test-Path $registryPath)) {
    Write-Host "ERROR: rc-deployments.json not found at $registryPath" -ForegroundColor Red
    exit 1
}

Add-Type -AssemblyName System.Web.Extensions
$registry = [System.Web.Script.Serialization.JavaScriptSerializer]::new().DeserializeObject((Get-Content $registryPath -Raw))
$hostMap = $registry["hosts"]
$apex = $registry["deployments"] | Where-Object { $_["name"] -eq "apex-research" } | Select-Object -First 1
if (-not $apex) {
    Write-Host "ERROR: apex-research deployment not found in registry" -ForegroundColor Red
    exit 1
}

$sshHost = $hostMap[$apex["hostAlias"]]
$sshPort = $apex["port"]
$sshUser = $apex["user"]
$sshKey = ($apex["key"] -replace '~', $env:USERPROFILE)

# Remote paths — apex container layout (verified via probe 2026-05-12)
$remoteTeamDir = "~/.claude/teams/apex-research"
$remoteConfig = "$remoteTeamDir/config.json"
$remoteOwnInbox = "$remoteTeamDir/inboxes/$Name.json"

# Watch poll interval (seconds) — 2s matches RFC <3s same-host baseline conservatively
$watchInterval = 2

# === ssh wrapper ===

function Invoke-Ssh {
    param([Parameter(Mandatory)][string]$RemoteCommand)
    # `-n` redirects stdin from /dev/null so ssh cannot consume the user's console
    # keystrokes while it runs. Without this, fast typing during a poll's ssh call
    # gets eaten by ssh — surfaced as the input-splitting Bug E. Belt-and-braces:
    # also pipe '' to ensure no upstream PS pipeline can feed bytes either.
    $sshArgs = @("-n", "-i", $sshKey, "-p", "$sshPort", "-o", "StrictHostKeyChecking=accept-new", "$sshUser@$sshHost", $RemoteCommand)
    return ('' | & ssh @sshArgs)
}

# === Commands ===

function Invoke-SshBase64Cmd {
    # Two-layer gotcha when invoking remote bash from Windows PowerShell:
    #  Layer 1 (PS source parsing): `\"` inside `"..."` is NOT an escape — PS treats
    #          the inner `"` as a string terminator. Mitigation: use SINGLE-quoted
    #          PS strings (no interpolation, no escape processing).
    #  Layer 2 (OpenSSH-Win32 → remote bash transport): backslashes in the remote
    #          command get stripped or re-interpreted by Windows' arg-passing rules.
    #          Mitigation: base64-encode the entire remote script on Windows, decode
    #          and eval on remote. Sidesteps every quoting layer.
    # This wrapper composes both fixes. Pass a single-quoted PS string with literal
    # shell content; we b64-encode and ship for remote eval.
    param([Parameter(Mandatory)][string]$RemoteShellScript)
    $b64 = [Convert]::ToBase64String([System.Text.Encoding]::UTF8.GetBytes($RemoteShellScript))
    return (Invoke-Ssh "echo $b64 | base64 -d | bash")
}

function Cmd-List {
    Write-Host ""
    Write-Host "Members of apex-research:" -ForegroundColor Cyan
    # Single-quoted PS string — passes `\(`, `\"`, `"-"` verbatim to b64-encoder.
    # $remoteConfig is interpolated via concatenation (single-quoted strings don't expand).
    $script = 'jq -r ''.members[] | "\(.name) :: agentType=\(.agentType // "-") backendType=\(.backendType // "-")"'' ' + $remoteConfig
    $out = Invoke-SshBase64Cmd $script
    $out | ForEach-Object {
        if ($_ -match "^$Name ::") {
            Write-Host "  $_" -ForegroundColor Green  # our ghost
        } else {
            Write-Host "  $_"
        }
    }
    Write-Host ""
}

function Cmd-Target {
    param([string]$NewTarget)
    if (-not $NewTarget) {
        Write-Host "Current target: $script:Target" -ForegroundColor Yellow
        return
    }
    $script:Target = $NewTarget
    Write-Host "Target set to: $NewTarget" -ForegroundColor Yellow
}

function Send-Line {
    param([string]$Body)
    if (-not $script:Target) {
        Write-Host "ERROR: No target set. Use /target <name> first." -ForegroundColor Red
        return
    }
    if (-not $Body) { return }

    # Build message JSON (canonical schema verified from apex inbox empirical observation)
    $ts = (Get-Date).ToUniversalTime().ToString("yyyy-MM-ddTHH:mm:ss.fffZ")
    # Omit `color` field — let apex harness apply the registered color for this ghost.
    # Including a per-message color override caused F3 cosmetic-anomaly during PoC:
    # apex displayed our self-asserted color (green) instead of registered (red).
    $msg = @{
        from = $Name
        text = $Body
        summary = ($Body.Substring(0, [Math]::Min(60, $Body.Length)))
        timestamp = $ts
        read = $false
    } | ConvertTo-Json -Compress

    # Remote append: ship msg JSON + python script as ONE base64 blob via
    # Invoke-SshBase64Cmd. Embedding msg as a python literal avoids the stdin
    # conflict (the heredoc would consume stdin; we have no second stdin channel).
    # b64-pass also dodges the OpenSSH-Win32 backslash-stripping Layer-2 gotcha.
    # The python b64-decodes the embedded msg JSON, then performs O_RDWR|O_CREAT +
    # fcntl.flock(LOCK_EX) read-modify-write under the lock — process-level atomic.
    $msgB64 = [Convert]::ToBase64String([System.Text.Encoding]::UTF8.GetBytes($msg))
    $remoteScript = @'
python3 <<PYEOF
import json, os, base64, fcntl
path = os.path.expanduser('__INBOX_PATH__')
msg = json.loads(base64.b64decode('__MSG_B64__').decode('utf-8'))
fd = os.open(path, os.O_RDWR | os.O_CREAT, 0o644)
try:
    fcntl.flock(fd, fcntl.LOCK_EX)
    raw = os.read(fd, 1<<24).decode('utf-8') or '[]'
    arr = json.loads(raw) if raw.strip() else []
    arr.append(msg)
    os.lseek(fd, 0, 0)
    os.ftruncate(fd, 0)
    os.write(fd, json.dumps(arr, ensure_ascii=False).encode('utf-8'))
finally:
    fcntl.flock(fd, fcntl.LOCK_UN)
    os.close(fd)
print('OK')
PYEOF
'@
    $remoteScript = $remoteScript.Replace('__INBOX_PATH__', "$remoteTeamDir/inboxes/$script:Target.json").Replace('__MSG_B64__', $msgB64)

    $startMs = [DateTimeOffset]::Now.ToUnixTimeMilliseconds()
    $result = Invoke-SshBase64Cmd $remoteScript
    $endMs = [DateTimeOffset]::Now.ToUnixTimeMilliseconds()
    $latencyMs = $endMs - $startMs

    if ($result -match "OK") {
        Write-Host "  -> $script:Target  ($latencyMs ms)" -ForegroundColor DarkGray
    } else {
        Write-Host "  -> $script:Target  FAILED: $result" -ForegroundColor Red
    }
}

# === Watch loop (background polling) ===
#
# Sketch-grade: poll inbox file mtime + size every $watchInterval seconds.
# When changed, fetch full content and display NEW unread messages.
# Track last-seen-count to avoid replaying old messages on each poll.

$script:lastSeenCount = -1  # sentinel: first iteration establishes baseline

function Show-Message {
    param([string]$Line, [bool]$IsBacklog = $false)
    try {
        $msg = $Line | ConvertFrom-Json
        $ts = [DateTime]::Parse($msg.timestamp).ToLocalTime().ToString("HH:mm:ss")
        Write-Host ""
        $prefix = if ($IsBacklog) { "[$ts BACKLOG]" } else { "[$ts]" }
        Write-Host "$prefix <$($msg.from)>" -ForegroundColor Cyan -NoNewline
        if ($msg.summary) { Write-Host " ($($msg.summary))" -ForegroundColor DarkCyan } else { Write-Host "" }
        Write-Host $msg.text
        Write-Host ""
    } catch {
        Write-Host "[malformed message in inbox] $Line" -ForegroundColor Red
    }
}

function Mark-MessagesRead {
    # Updates inbox file in place: sets read=true on messages whose timestamp is
    # in $Timestamps. Uses same single-ssh+python+fcntl.flock primitive as Send-Line
    # for atomic read-modify-write semantics. Idempotent — already-read messages stay
    # read; unmatched timestamps are no-ops.
    #
    # External-CLI members must replicate the harness-side read-flag contract:
    # without this, every relaunch re-surfaces the same backlog (Bug C). The flag
    # is a substrate-side obligation, not an internal-state convenience.
    param([Parameter(Mandatory)][string[]]$Timestamps)
    if ($Timestamps.Count -eq 0) { return }

    $tsJson = ConvertTo-Json $Timestamps -Compress
    $tsB64 = [Convert]::ToBase64String([System.Text.Encoding]::UTF8.GetBytes($tsJson))

    $remoteScript = @'
python3 <<PYEOF
import json, os, base64, fcntl
path = os.path.expanduser('__INBOX_PATH__')
targets = set(json.loads(base64.b64decode('__TS_B64__').decode('utf-8')))
fd = os.open(path, os.O_RDWR | os.O_CREAT, 0o644)
try:
    fcntl.flock(fd, fcntl.LOCK_EX)
    raw = os.read(fd, 1<<24).decode('utf-8') or '[]'
    arr = json.loads(raw) if raw.strip() else []
    for m in arr:
        if m.get('timestamp') in targets:
            m['read'] = True
    os.lseek(fd, 0, 0)
    os.ftruncate(fd, 0)
    os.write(fd, json.dumps(arr, ensure_ascii=False).encode('utf-8'))
finally:
    fcntl.flock(fd, fcntl.LOCK_UN)
    os.close(fd)
print('OK')
PYEOF
'@
    $remoteScript = $remoteScript.Replace('__INBOX_PATH__', $remoteOwnInbox).Replace('__TS_B64__', $tsB64)
    [void](Invoke-SshBase64Cmd $remoteScript)
}

function Poll-Inbox {
    # Returns $true iff at least one message was displayed this poll. Caller uses
    # the return to decide whether to emit a separator newline and redraw the
    # prompt — silent no-op on empty polls prevents the per-tick blank-line drift.
    # Side effect: marks displayed messages read=true on apex side (Bug C contract).
    $remoteCmd = "if [ -f $remoteOwnInbox ]; then jq -c '.[]' $remoteOwnInbox 2>/dev/null; fi"
    $allLines = @(Invoke-SshBase64Cmd $remoteCmd)
    $totalCount = $allLines.Count
    $displayed = $false
    $markRead = New-Object System.Collections.Generic.List[string]

    if ($script:lastSeenCount -eq -1) {
        foreach ($line in $allLines) {
            try {
                $msg = $line | ConvertFrom-Json
                if (-not $msg.read) {
                    Show-Message $line -IsBacklog $true
                    $displayed = $true
                    if ($msg.timestamp) { $markRead.Add([string]$msg.timestamp) }
                }
            } catch { }
        }
        $script:lastSeenCount = $totalCount
        if ($markRead.Count -gt 0) { Mark-MessagesRead -Timestamps $markRead.ToArray() }
        return $displayed
    }

    if ($totalCount -gt $script:lastSeenCount) {
        $newOnes = $allLines[$script:lastSeenCount..($totalCount - 1)]
        foreach ($line in $newOnes) {
            Show-Message $line
            $displayed = $true
            try {
                $msg = $line | ConvertFrom-Json
                if ($msg.timestamp) { $markRead.Add([string]$msg.timestamp) }
            } catch { }
        }
        $script:lastSeenCount = $totalCount
        if ($markRead.Count -gt 0) { Mark-MessagesRead -Timestamps $markRead.ToArray() }
    }
    return $displayed
}

# === Startup banner ===

# Em-dash built from codepoint so banner survives even if the .ps1 itself is read as
# ANSI by older PowerShell hosts. Belt-and-braces with the [Console]::OutputEncoding wiring above.
$emDash = [char]0x2014

Write-Host ""
Write-Host "ghost-chat PoC $emDash RFC #66 cross-host verification" -ForegroundColor Cyan
Write-Host "  ghost name : $Name" -ForegroundColor DarkGray
Write-Host "  apex ssh   : $sshUser@$sshHost`:$sshPort" -ForegroundColor DarkGray
Write-Host "  own inbox  : $remoteOwnInbox" -ForegroundColor DarkGray
Write-Host "  target     : $(if ($Target) { $Target } else { "(unset $emDash use /target <name>)" })" -ForegroundColor DarkGray
Write-Host ""
Write-Host "Commands: /list  /target <name>  /exit  (anything else = send to target)" -ForegroundColor DarkGray
Write-Host ""

# Pre-flight: confirm ghost is registered (F1 verification gate).
$members = Invoke-SshBase64Cmd "jq -r '.members[].name' $remoteConfig"
if ($members -notcontains $Name) {
    Write-Host "WARNING: '$Name' NOT in apex members[]. F1 not satisfied." -ForegroundColor Yellow
    Write-Host "  Ask apex team-lead to register before proceeding (RFC #66 ACL-is-one-sided)." -ForegroundColor Yellow
    Write-Host "  Continuing in /list-and-watch-only mode; sends will be rejected by harness." -ForegroundColor Yellow
    Write-Host ""
} else {
    Write-Host "F1 OK: '$Name' is registered in apex members[]." -ForegroundColor Green
    Write-Host ""
}

# === Main loop ===
#
# Non-blocking input + interleaved polling. The previous version used Read-Host
# which BLOCKED until Enter — so the 2s watch interval never actually fired while
# the user was idle waiting at a prompt. ReadKey(NoEcho,IncludeKeyDown) returns
# immediately; KeyAvailable guards it. We poll keys + poll inbox in the same loop,
# only sleeping briefly when neither has work, so inbox arrivals during typing
# surface within $watchInterval seconds rather than "on next Enter."
#
# Buffer is local to the loop and echoed manually (we suppress ReadKey's echo to
# control how new-inbox-message redraws interact with the in-progress input).

# Establish watch baseline. Cast to [void] — Poll-Inbox returns $true/$false and
# without the cast PowerShell prints "True" to the console as a value-leak.
[void](Poll-Inbox)

function Write-Prompt {
    param([string]$Buffer)
    Write-Host "$Name> " -NoNewline -ForegroundColor Yellow
    if ($Buffer) { Write-Host $Buffer -NoNewline }
}

$buffer = ""
$lastPoll = [DateTime]::Now
$pollIntervalMs = $watchInterval * 1000
Write-Prompt -Buffer $buffer

while ($true) {
    # Drain any keys available right now.
    $consumedKey = $false
    while ([Console]::KeyAvailable) {
        $consumedKey = $true
        $key = [Console]::ReadKey($true)  # $true = NoEcho

        if ($key.Key -eq [ConsoleKey]::Enter) {
            Write-Host ""  # newline after the echoed buffer
            $line = $buffer
            $buffer = ""

            if ($line) {
                $trimmed = $line.Trim()
                if ($trimmed -eq "/exit") {
                    Write-Host "Exiting. (Ghost entry persists on apex side per PO-managed registration.)" -ForegroundColor DarkGray
                    return
                } elseif ($trimmed -eq "/list") {
                    Cmd-List
                } elseif ($trimmed -match "^/target(?:\s+(\S+))?$") {
                    Cmd-Target -NewTarget $Matches[1]
                } elseif ($trimmed -match "^/") {
                    Write-Host "Unknown command: $trimmed" -ForegroundColor Red
                } else {
                    Send-Line -Body $line
                }
            }

            # Poll right after a send/command so any synchronous reply is caught fast.
            [void](Poll-Inbox)
            $lastPoll = [DateTime]::Now
            Write-Prompt -Buffer $buffer
        } elseif ($key.Key -eq [ConsoleKey]::Backspace) {
            if ($buffer.Length -gt 0) {
                $buffer = $buffer.Substring(0, $buffer.Length - 1)
                # Erase last char on screen: backspace + space + backspace
                Write-Host "`b `b" -NoNewline
            }
        } elseif ($key.KeyChar -and [int]$key.KeyChar -ge 32) {
            $buffer += $key.KeyChar
            Write-Host -NoNewline $key.KeyChar
        }
    }

    # Interval poll when no key arrived. Silent no-op on empty polls: only break
    # the in-progress prompt line + redraw if Poll-Inbox actually displayed messages.
    # This prevents idle ticks from accumulating blank lines in the terminal.
    $now = [DateTime]::Now
    if (-not $consumedKey -and ($now - $lastPoll).TotalMilliseconds -ge $pollIntervalMs) {
        # Use a deferred-output approach: capture into a flag whether anything surfaced.
        # If nothing surfaced, $displayed is $false and we touch nothing on screen.
        # Note: any "in-progress prompt" the user was looking at is preserved untouched.
        $displayed = Poll-Inbox
        $lastPoll = $now
        if ($displayed) {
            # Show-Message wrote starting on a new line and added trailing blank line;
            # redraw the prompt + whatever the user had typed so far.
            Write-Prompt -Buffer $buffer
        }
    }

    if (-not $consumedKey) {
        # Short sleep keeps CPU low while idle. 50ms is well under perceptible
        # typing latency and small relative to the 2s poll cadence.
        Start-Sleep -Milliseconds 50
    }
}
